{
  "manifest_version": 3,
  "name": "Athena Tools",
  "version": "1.0.0",
  "description": "UI improvements and Headline Lab SEO tools for the Athena CMS post editor.",

  "permissions": ["storage"],

  "host_permissions": [
    "*://admin.govexec.com/*",
    "*://www.navybook.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://admin.govexec.com/*"],
      "js": ["content/main.js"],
      "css": ["styles/tweaks.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Athena Tools"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [{
    "resources": ["icons/*"],
    "matches": ["*://admin.govexec.com/*"]
  }]
}